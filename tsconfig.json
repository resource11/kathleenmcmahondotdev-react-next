{
	"extends": "astro/tsconfigs/base",
	"compilerOptions": {
		"strictNullChecks": true,
		"allowJs": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@/utils": ["src/utils/*"]
		},
		// For Solid
		// /** @jsxImportSource solid-js */
		"jsx": "preserve",
		"jsxImportSource": "react",
		"types": ["astro/client", "vitest/globals", "@testing-library/jest-dom"]
	}
}
