---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
import BlogHeroAccent from '@/assets/images/blog-hero-accent.svg';
import MDXClientWrapper from '@/components/MDXClientWrapper.jsx';
import '../styles/layout-styles/post-mdx-layout.css';
---

<BaseLayout h1Title={frontmatter.title}>
	<article class="bodyWrapper">
		<Image
			src={BlogHeroAccent}
			alt=""
			class="blogHeroAccent"
		/>
		<MDXClientWrapper client:load>
			<slot />
		</MDXClientWrapper>
	</article>
</BaseLayout>
