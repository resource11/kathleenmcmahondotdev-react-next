---
import CommonHead from '../components/astro/CommonHead.astro';
import Header from '../components/astro/Header/Header.astro';
import Footer from '../components/astro/Footer/Footer.astro';
import Link from '../components/astro/Link/Link.astro';
import '../styles/layout-styles/layout.css';
const { pageTitle } = Astro.props;
---

<html lang='en' transition:animate='fade'>
	<head>
		<CommonHead />
		<meta charset='utf-8' />
		<link rel='icon' href='/favicon.png' />
		<link rel='stylesheet' href='/prism-night-owl.css' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class='contentWrapper'>
			<Header />
			<main id='main' class='main'>
				<slot />
				<Link
					size='small'
					href='#top'
					icon='arrow-up'
					iconBefore
					iconClasses='icon'
					linkClasses='backToTop'>
					Back to top
				</Link>
			</main>
			<Footer />
		</div>
	</body>
</html>
