---
import { getCollection } from 'astro:content';

interface Props {
	currentSlug: string;
}
const { currentSlug } = Astro.props;

const all = (await getCollection('privatePortfolio')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((entry) => entry.id === currentSlug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;
---

{
	(prev || next) && (
		<nav aria-label='Case study navigation' class='caseStudyNav'>
			<ul>
				{prev && (
					<li class='prev'>
						<a href={`/private/${prev.id}`}>
							<span class='label'>← Previous case study</span>
							<span class='title'>{prev.data.title}</span>
						</a>
					</li>
				)}
				{next && (
					<li class='next'>
						<a href={`/private/${next.id}`}>
							<span class='label'>Next case study →</span>
							<span class='title'>{next.data.title}</span>
						</a>
					</li>
				)}
			</ul>
		</nav>
	)
}

<style>
	.caseStudyNav {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid currentColor;
	}
	.caseStudyNav ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.caseStudyNav .next {
		margin-left: auto;
		text-align: right;
	}
	.caseStudyNav a {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		text-decoration: none;
	}
	.caseStudyNav a:hover .title {
		text-decoration: underline;
	}
	.label {
		font-size: 0.875rem;
		opacity: 0.7;
	}
	.title {
		font-weight: 600;
	}
</style>
