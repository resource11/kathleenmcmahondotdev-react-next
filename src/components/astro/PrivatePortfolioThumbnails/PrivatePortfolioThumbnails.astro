---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const items = (await getCollection('privatePortfolio')).sort(
	(a, b) => a.data.order - b.data.order,
);
---

{
	items.length > 0 && (
		<section aria-labelledby='private-portfolio-heading' class='privatePortfolioThumbnails'>
			<h2 id='private-portfolio-heading'>Private case studies</h2>
			<ul>
				{items.map((item) => (
					<li>
						<a href={`/private/${item.id}`}>
							<div class='thumbnail'>
								{item.data.coverImage ? (
									<Image src={item.data.coverImage} alt='' loading='lazy' />
								) : (
									<div class='thumbnailFallback' aria-hidden='true' />
								)}
								<span class='lockOverlay'>🔒 Private — password required</span>
							</div>
							<h3>{item.data.title}</h3>
							<p>{item.data.summary}</p>
						</a>
					</li>
				))}
			</ul>
		</section>
	)
}

<style>
	.privatePortfolioThumbnails {
		margin: 2rem 0;
	}
	.privatePortfolioThumbnails ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
	}
	.privatePortfolioThumbnails a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.privatePortfolioThumbnails a:hover h3 {
		text-decoration: underline;
	}
	.thumbnail {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: 4px;
		background: #f0f0f0;
	}
	.thumbnail :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.thumbnailFallback {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #e0e0e0, #c0c0c0);
	}
	.lockOverlay {
		position: absolute;
		bottom: 0.5rem;
		left: 0.5rem;
		padding: 0.25rem 0.5rem;
		background: rgba(0, 0, 0, 0.75);
		color: #fff;
		font-size: 0.75rem;
		border-radius: 3px;
	}
	.privatePortfolioThumbnails h3 {
		margin: 0.75rem 0 0.25rem;
		font-size: 1.125rem;
	}
	.privatePortfolioThumbnails p {
		margin: 0;
		font-size: 0.9375rem;
		opacity: 0.85;
	}
</style>
